# SafeDesk Environment Example
# Copy this file to .env locally and fill in real values.
# Never commit .env.

SAFEDESK_ENV=development

SAFEDESK_EMAIL_SENDER_ADDRESS=
SAFEDESK_EMAIL_APP_PASSWORD=
SAFEDESK_OTP_RECEIVER_EMAIL=

SAFEDESK_ENABLE_REAL_EMAIL=false
ENABLE_REAL_SHUTDOWN=false
ENABLE_REAL_LOCKDOWN=false

# Real email, shutdown, and lockdown are disabled by default.
# Enable them only in a private local environment after reviewing safety controls.
