{
  "app": {
    "name": "SafeDesk",
    "version": "1.0.0",
    "environment": "development",
    "demo_safe_mode": true
  },
  "owner_profile": {
    "owner_name": "",
    "owner_email": ""
  },
  "setup": {
    "completed": false,
    "setup_version": 1,
    "completed_at": "",
    "last_updated_at": ""
  },
  "security_mode": {
    "default_mode": "demo_safe",
    "available_modes": [
      "standard",
      "strict",
      "silent_evidence",
      "demo_safe"
    ]
  },
  "app_modes": {
    "default_start_mode": "launch",
    "allow_public_lock_placeholder": true,
    "allow_admin_console_from_launch": true
  },
  "admin_gate": {
    "enabled": true,
    "foundation_enabled": true,
    "demo_only": true,
    "require_password_if_configured": true,
    "allow_development_continue_if_unconfigured": true,
    "max_attempts": 3,
    "lockout_seconds": 30
  },
  "background_agent": {
    "enabled": true,
    "foundation_enabled": true,
    "demo_only": true,
    "system_tray_enabled": true,
    "minimize_to_tray": true,
    "close_to_tray": false,
    "allow_exit_from_tray": true,
    "show_tray_notifications": false
  },
  "global_shortcut": {
    "enabled": true,
    "foundation_enabled": true,
    "demo_only": true,
    "shortcut_enabled": true,
    "hotkey": "ctrl+alt+l",
    "activation_action": "public_lock",
    "require_app_running": true,
    "allow_when_minimized_to_tray": true,
    "allow_when_admin_console_open": true,
    "allow_when_public_lock_open": false,
    "supported_platforms": [
      "Windows"
    ]
  },
  "lockdown_display": {
    "enabled": true,
    "foundation_enabled": true,
    "demo_only": true,
    "fullscreen_enabled": true,
    "multi_display_enabled": true,
    "borderless_enabled": true,
    "topmost_enabled": true,
    "primary_display_required": true,
    "fallback_to_primary_display": true,
    "allow_development_escape": true,
    "development_escape_timeout_seconds": 30,
    "max_display_windows": 6
  },
  "safe_interaction_lock": {
    "enabled": true,
    "foundation_enabled": true,
    "demo_only": true,
    "focus_recovery_enabled": true,
    "focus_recovery_interval_seconds": 2,
    "lift_windows_on_recovery": true,
    "reapply_topmost_on_recovery": true,
    "focus_primary_on_activation": true,
    "focus_primary_on_recovery": false,
    "cleanup_on_route_change": true,
    "prevent_duplicate_activation": true,
    "log_lifecycle_events": true
  },
  "feature_flags": {
    "enable_real_email": false,
    "enable_real_shutdown": false,
    "enable_real_lockdown": false
  },
  "face_recognition": {
    "enabled": false,
    "backend": "planned",
    "liveness_check_enabled": false,
    "minimum_confidence": 0.6
  },
  "owner_face_registration": {
    "enabled": true,
    "required_samples": 5,
    "camera_index": 0,
    "samples_dir": "data/owner/samples",
    "manifest_path": "data/config/owner_registration_manifest.json",
    "image_format": "jpg",
    "image_quality": 90
  },
  "owner_recognition": {
    "enabled": true,
    "model_name": "ArcFace",
    "detector_backend": "retinaface",
    "distance_metric": "cosine",
    "align": true,
    "enforce_detection": true,
    "minimum_samples_required": 5,
    "profile_path": "data/config/owner_recognition_profile.json",
    "cache_dir": "data/cache/recognition",
    "demo_threshold": 0.68,
    "uncertain_margin": 0.05,
    "offline_after_model_setup": true
  },
  "liveness": {
    "enabled": true,
    "challenge_duration_seconds": 8,
    "movement_threshold_ratio": 0.08,
    "minimum_detection_frames": 3,
    "camera_index": 0,
    "demo_only": true
  },
  "intruder_detection": {
    "enabled": true,
    "demo_only": true,
    "camera_index": 0,
    "intruder_images_dir": "data/intruders",
    "manifest_path": "data/config/intruder_capture_manifest.json",
    "image_format": "jpg",
    "image_quality": 90,
    "minimum_owner_samples_required": 5,
    "capture_unknown_only": true
  },
  "authentication": {
    "password_fallback_enabled": false,
    "panic_code_enabled": false,
    "auth_foundation_enabled": true,
    "demo_only": true,
    "secrets_path": "secrets.local.json",
    "hash_algorithm": "pbkdf2_sha256",
    "pbkdf2_iterations": 390000,
    "minimum_password_length": 8,
    "minimum_panic_code_length": 6,
    "max_unlock_attempts": 3,
    "lockout_seconds": 30
  },
  "recovery_codes": {
    "enabled": true,
    "foundation_enabled": true,
    "demo_only": true,
    "code_count": 5,
    "code_length": 16,
    "allowed_special_characters": "!@#$%^&*()-_=+[]{}?",
    "single_use": true
  },
  "otp": {
    "enabled": false,
    "otp_foundation_enabled": true,
    "demo_only": true,
    "delivery_method": "email",
    "code_length": 6,
    "expires_seconds": 120,
    "max_attempts": 3,
    "resend_limit": 2,
    "resend_cooldown_seconds": 30
  },
  "email": {
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587,
    "use_tls": true,
    "timeout_seconds": 15,
    "sender_display_name": "SafeDesk",
    "demo_only": true
  },
  "threat_levels": {
    "enabled": false,
    "foundation_enabled": true,
    "demo_only": true,
    "initial_level": 0,
    "max_level": 5,
    "forceful_attempt_threshold": 3,
    "repeated_unknown_threshold": 3,
    "failed_password_threshold": 3,
    "failed_otp_threshold": 3,
    "forced_exit_threshold": 1,
    "state_path": "data/config/threat_state.json"
  },
  "protected_mode": {
    "enabled": false,
    "foundation_enabled": true,
    "demo_only": true,
    "state_path": "data/config/protected_mode_state.json",
    "allow_manual_arm": true,
    "allow_manual_activation": true,
    "allow_manual_recovery": true,
    "link_threat_level_demo": true,
    "activation_candidate_threat_level": 4,
    "shutdown_candidate_threat_level": 5
  },
  "shutdown": {
    "foundation_enabled": true,
    "real_shutdown_enabled": false,
    "demo_shutdown_only": true,
    "real_shutdown_command_enabled": false,
    "state_path": "data/config/shutdown_state.json",
    "shutdown_after_threat_level": 5,
    "warning_seconds": 30,
    "countdown_seconds": 30,
    "allow_demo_countdown": true,
    "allow_cancel": true,
    "allow_recovery_cancel": true,
    "require_manual_confirmation": true,
    "link_threat_level_demo": true,
    "link_protected_mode_demo": true,
    "allow_guarded_real_shutdown": false,
    "real_shutdown_supported_platforms": [
      "Windows"
    ],
    "real_shutdown_countdown_seconds": 60,
    "allow_abort_real_shutdown": true,
    "real_shutdown_requires_confirmation_phrase": true,
    "real_shutdown_confirmation_phrase": "SHUT DOWN SAFEDESK TEST"
  },
  "lockdown": {
    "real_lockdown_enabled": false,
    "demo_lockdown_only": true,
    "allow_recovery_exit": true
  },
  "alarm": {
    "enabled": false,
    "volume": 0.5,
    "audio_file": ""
  },
  "logging": {
    "enabled": true,
    "database_path": "data/logs/safedesk.sqlite3",
    "log_level": "INFO",
    "demo_only": true,
    "max_recent_events": 50,
    "retention_days": 30
  },
  "paths": {
    "owner_data_dir": "data/owner",
    "intruder_data_dir": "data/intruders",
    "logs_dir": "data/logs",
    "cache_dir": "data/cache",
    "config_dir": "data/config"
  },
  "privacy": {
    "store_intruder_images": false,
    "store_owner_images": false,
    "local_only_by_default": true,
    "cloud_sync_enabled": false
  },
  "ui": {
    "theme": "dark",
    "color_theme": "blue",
    "window_width": 1100,
    "window_height": 700,
    "minimum_width": 900,
    "minimum_height": 600,
    "start_maximized": false
  }
}
